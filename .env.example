# ============================================
# Telegram UserBot - Configuration file
# Copy this file to .env and fill in your data
# ============================================

# ============================================
# TELEGRAM API (REQUIRED!)
# Get it at https://my.telegram.org/apps
# ============================================
API_ID=12345678
API_HASH=your_api_hash_here
PHONE_NUMBER=+375291234567

# ============================================
# OPENROUTER API (REQUIRED!)
# Get your key at https://openrouter.ai/keys
# ============================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ============================================
# AI MODEL
# ============================================
# Available models:
# - meta-llama/llama-3.3-70b-instruct:free (free)
# - meta-llama/llama-3.3-70b-instruct (paid)
# - qwen/qwen-2.5-72b-instruct
# - anthropic/claude-3.5-sonnet
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ============================================
# SERVER SETTINGS
# ============================================
# Mode: webhook or polling
SERVER_MODE=polling

# Data/session folder (optional)
# Railway/Render: can leave empty (defaults to /tmp/data)
# If you attach a persistent volume, specify the volume path, e.g.: /data
DATA_DIR=

# Server URL (for webhook mode)
# Example: https://your-domain.com or IP address
WEBHOOK_URL=https://your-server.com

# Webhook server port
WEBHOOK_PORT=8443

# Webhook endpoint path
WEBHOOK_PATH=/webhook

# Server host (0.0.0.0 for all interfaces)
SERVER_HOST=0.0.0.0

# SSL certificates (for HTTPS webhook)
# Leave empty if using HTTP or reverse proxy
SSL_CERT=/path/to/cert.pem
SSL_KEY=/path/to/key.pem

# ============================================
# CHARACTER SETTINGS
# ============================================
BOT_NAME=Diana
BOT_AGE=18
BOT_CITY=NYC

# ============================================
# BEHAVIOR SETTINGS
# ============================================
# Max number of messages in memory
MAX_HISTORY=50

# Number of style examples for prompt
STYLE_EXAMPLES_COUNT=15

# Simulate typing (true/false)
TYPING_SIMULATION=true

# Delay before response (seconds)
MIN_TYPING_DELAY=1.0
MAX_TYPING_DELAY=3.0

# Max response length (tokens)
MAX_TOKENS=200

# Generation temperature (0.0 - 1.0)
TEMPERATURE=0.7

# Initial trust level
INITIAL_TRUST=50

# ============================================
# SECURITY
# ============================================
# Chat IDs where bot will respond (empty = all)
# Format: 123456789,987654321 (comma-separated)
ALLOWED_CHATS=

# Chat IDs where bot will NOT respond (blocklist)
# Format: 123456789,987654321 (comma-separated)
BLOCKED_CHATS=

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO

ROULETTE_BOT=anonymous_chat_bot  # or exact username of the chat roulette bot
TARGET_USERNAME=your_username    # where to send people
